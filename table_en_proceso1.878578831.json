	"sql": "SELECT\r\n\tfecha,\r\n\tdate_format(fecha,'%H:%i') as tiempo,\r\n\tlimpiador,\r\n\tcuenta,\r\n\tid_medidor,\r\n\tfecha_limpio,\r\n\tdate_format(fecha_limpio,'%H:%i') as hr_limpio,\r\n\tstatus,\r\n\tconcat(\"lym/\",fotoa,\".jpeg\") as fotoa,\r\n\tconcat(\"lym/\",fotod,\".jpeg\") as fotod,\r\n\tlat,\r\n\tlon,\r\n\tlatf,\r\n\tlonf,\r\n    '' as mapa,\r\n    '' as mapaf,\r\n    direccion\r\nFROM\r\n\ten_proceso\r\nWHERE\r\n    status='Limpio'\r\nORDER BY\r\n    fecha\r\nDESC",
	"type": 1,
	"connId": "conn",
	"originalTable": "en_proceso",
